{
  "compilerOptions": {
    // Compile to modern JS — Vite handles the final bundling
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    // "bundler" lets you import .ts/.tsx without writing extensions
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,

    // Each file is compiled in isolation (required by Vite)
    "isolatedModules": true,
    // TypeScript only type-checks; Vite does the actual emit
    "noEmit": true,

    // React 17+ JSX transform — no need to import React in every file
    "jsx": "react-jsx",

    // strict mode catches the most common bugs at compile time
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
