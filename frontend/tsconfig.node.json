{
  "compilerOptions": {
    // vite.config.ts runs in Node, not the browser — separate config keeps it clean
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true
  },
  "include": ["vite.config.ts"]
}
